## Transformation Pipeline Detail

### 1. Session → AgentMessage[]

```typescript
// buildSessionContext() in session-manager.ts
// Walks tree, handles compaction, returns messages

function buildSessionContext(entries, leafId?, byId?): SessionContext {
  // Walk from leaf to root
  const path = [];
  let current = leaf;
  while (current) {
    path.unshift(current);
    current = byId.get(current.parentId);
  }

  // Extract settings (latest wins)
  for (entry of path) {
    if (entry.type === "thinking_level_change") thinkingLevel = entry.thinkingLevel;
    if (entry.type === "model_change") model = { provider, modelId };
    if (entry.type === "compaction") compaction = entry;
  }

  // Build messages with compaction handling
  if (compaction) {
    messages.push(createCompactionSummaryMessage(...));
    // Emit kept messages (from firstKeptEntryId)
    // Emit messages after compaction
  } else {
    // Emit all messages
  }

  return { messages, thinkingLevel, model };
}
```

### 2. AgentMessage[] → Message[] (convertToLlm)

```typescript
// convertToLlm() in messages.ts
// Filters app-only types, transforms to LLM format

function convertToLlm(messages: AgentMessage[]): Message[] {
  return messages.map(m => {
    switch (m.role) {
      case "bashExecution":
        if (m.excludeFromContext) return undefined;
        return { role: "user", content: [{ type: "text", text: bashExecutionToText(m) }], timestamp: m.timestamp };
      case "custom":
        return { role: "user", content: m.content, timestamp: m.timestamp };
      case "branchSummary":
        return { role: "user", content: [{ type: "text", text: wrapSummary(m.summary) }], timestamp: m.timestamp };
      case "compactionSummary":
        return { role: "user", content: [{ type: "text", text: wrapCompaction(m.summary) }], timestamp: m.timestamp };
      case "user":
      case "assistant":
      case "toolResult":
        return m;  // Pass through unchanged
      default:
        return undefined;
    }
  }).filter(m => m !== undefined);
}
```

### 3. Message[] → Message[] (transformMessages)

```typescript
// transformMessages() in transform-messages.ts
// Cross-provider compatibility, handles thinking blocks

function transformMessages(messages: Message[], model: Model<TApi>): Message[] {
  const toolCallIdMap = new Map<string, string>();

  return messages.map(msg => {
    if (msg.role === "assistant") {
      const isSameModel = msg.provider === model.provider && msg.api === model.api;

      return {
        ...msg,
        content: msg.content.flatMap(block => {
          if (block.type === "thinking") {
            // Redacted thinking: only valid for same model
            if (block.redacted && !isSameModel) return [];
            // Cross-provider: convert to text
            if (!isSameModel && block.thinking) {
              return { type: "text", text: block.thinking };
            }
            return block;
          }
          if (block.type === "toolCall") {
            // Normalize tool call IDs for API compatibility
            // Remove provider-specific signatures for cross-provider
          }
          return block;
        })
      };
    }
    return msg;
  });
  // Also inserts synthetic tool results for orphaned tool calls
}
```

### 4. Message[] → Provider Format

Each provider file (anthropic.ts, openai-completions.ts, etc.) converts:
- `Message[]` to provider-specific request format
- Handles caching headers (Anthropic: cache_control, OpenAI: previous_response_id)
- Converts tools to provider format

